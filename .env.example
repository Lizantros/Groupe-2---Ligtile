APP_NAME="HUG Collectes"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# SQLite — pas besoin de serveur, le fichier est créé par `php artisan migrate`
DB_CONNECTION=sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120

CACHE_STORE=database

FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
